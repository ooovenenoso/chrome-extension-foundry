{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ResearchSnapshot",
  "type": "object",
  "required": ["fetched_at", "sources"],
  "properties": {
    "slot": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}(-\\d{2})?$",
      "description": "Run identifier YYYY-MM-DD-HH (or YYYY-MM-DD). Replaces week as primary key."
    },
    "week": {
      "type": "string",
      "pattern": "^\\d{4}-W\\d{2}$",
      "description": "ISO week (YYYY-Www) derived from slot for backwards-compat."
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time"
    },
    "partial": {
      "type": "boolean",
      "default": false,
      "description": "True if the source was unreachable. Pipeline still runs."
    },
    "sources": {
      "type": "object",
      "required": ["ai_generated"],
      "properties": {
        "ai_generated": { "$ref": "#/$defs/Source" }
      },
      "additionalProperties": false
    },
    "meta": {
      "type": "object",
      "properties": {
        "ai_generated": { "type": "boolean" },
        "model": { "type": "string" },
        "schema_version": { "type": "string" }
      }
    }
  },
  "$defs": {
    "Source": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "enum": ["ok", "partial", "error"] },
        "fetched_count": { "type": "integer", "minimum": 0 },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_id", "title", "url", "timestamp"],
            "properties": {
              "source_id": { "type": "string" },
              "title": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "timestamp": { "type": "string", "format": "date-time" },
              "metric": {
                "type": "object",
                "additionalProperties": { "type": ["number", "string"] }
              },
              "category": { "type": "string" },
              "notes": { "type": "string" },
              "pain": { "type": "string" },
              "monetization": { "type": "string" }
            }
          }
        },
        "error": { "type": "string" },
        "meta": {
          "type": "object",
          "properties": {
            "model": { "type": "string" },
            "generated_at": { "type": "string", "format": "date-time" },
            "dedup_against": { "type": "integer", "minimum": 0 },
            "rejected_as_duplicate": { "type": "integer", "minimum": 0 }
          }
        }
      }
    }
  }
}
