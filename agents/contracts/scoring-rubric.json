{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chrome-extension-idea-factory/schemas/scoring-rubric.json",
  "title": "ScoringRubric",
  "description": "Deterministic rubric for ranking Chrome extension ideas. Same input → same output, no LLM in the score loop.",
  "type": "object",
  "required": ["version", "axes", "weights", "thresholds", "monetization_models"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver of the rubric. Bumping MAJOR changes top-5."
    },
    "axes": {
      "type": "object",
      "required": ["demand", "wtp", "buildability", "defensibility"],
      "properties": {
        "demand": {
          "type": "object",
          "description": "Real, measurable user pain / interest signals.",
          "properties": {
            "description": { "type": "string" },
            "signals": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["source", "metric", "scoring"],
                "properties": {
                  "source": { "enum": ["cws_installs", "cws_rating", "hn_points", "reddit_score", "reddit_comments"] },
                  "metric": { "type": "string" },
                  "scoring": {
                    "type": "object",
                    "required": ["buckets"],
                    "properties": {
                      "buckets": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["min", "score"],
                          "properties": {
                            "min": { "type": "number" },
                            "max": { "type": "number" },
                            "score": { "type": "number", "minimum": 0, "maximum": 10 }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "wtp": {
          "type": "object",
          "description": "Willingness-to-pay signal — is there a clear buyer with a credit card?",
          "properties": {
            "description": { "type": "string" },
            "tiers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["audience", "score"],
                "properties": {
                  "audience": { "enum": ["b2b_devtool", "b2b_sales", "consumer_productivity", "consumer_privacy", "consumer_ai_wrapper", "developer_internal"] },
                  "score": { "type": "number", "minimum": 0, "maximum": 10 }
                }
              }
            }
          }
        },
        "buildability": {
          "type": "object",
          "description": "Can one engineer ship MVP in ≤6 weeks?",
          "properties": {
            "description": { "type": "string" },
            "factors": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "delta"],
                "properties": {
                  "name": { "type": "string" },
                  "delta": { "type": "number", "minimum": -5, "maximum": 5 }
                }
              }
            }
          }
        },
        "defensibility": {
          "type": "object",
          "description": "How hard is it to clone? Moats: data, network, brand, complexity.",
          "properties": {
            "description": { "type": "string" },
            "factors": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["moat", "score"],
                "properties": {
                  "moat": { "enum": ["none", "trivial_clone", "moderate_clone", "hard_clone"] },
                  "score": { "type": "number", "minimum": 0, "maximum": 10 }
                }
              }
            }
          }
        }
      }
    },
    "weights": {
      "type": "object",
      "description": "Must sum to 1.0. Change is a MAJOR bump.",
      "required": ["demand", "wtp", "buildability", "defensibility"],
      "properties": {
        "demand": { "type": "number", "minimum": 0, "maximum": 1 },
        "wtp": { "type": "number", "minimum": 0, "maximum": 1 },
        "buildability": { "type": "number", "minimum": 0, "maximum": 1 },
        "defensibility": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "thresholds": {
      "type": "object",
      "description": "Cutoffs that gate downstream actions.",
      "properties": {
        "min_score_for_idea_pool": {
          "type": "number",
          "description": "Below this, the candidate is dropped from docs/ideas/.",
          "default": 5.0
        },
        "min_score_for_spec": {
          "type": "number",
          "description": "Below this, spec-writer refuses to draft.",
          "default": 7.0
        },
        "min_score_for_digest_ping": {
          "type": "number",
          "description": "Below this, weekly cron stays silent.",
          "default": 7.0
        }
      }
    },
    "monetization_models": {
      "type": "object",
      "description": "Maps audience → default monetization. Spec-writer uses this to populate §10.",
      "additionalProperties": {
        "type": "object",
        "required": ["model", "tier", "monthly_price_usd"],
        "properties": {
          "model": { "type": "string" },
          "tier": { "enum": ["free", "tip_jar", "freemium_saas", "per_seat", "quota_based", "donation"] },
          "monthly_price_usd": { "type": ["number", "null"] }
        }
      }
    },
    "deduplication": {
      "type": "object",
      "description": "How to detect overlap with prior candidates.",
      "properties": {
        "lookback_weeks": { "type": "number", "default": 8 },
        "jaccard_threshold": { "type": "number", "default": 0.3, "minimum": 0, "maximum": 1 }
      }
    }
  },
  "examples": [
    {
      "version": "1.0.0",
      "weights": { "demand": 0.30, "wtp": 0.35, "buildability": 0.20, "defensibility": 0.15 }
    }
  ]
}
