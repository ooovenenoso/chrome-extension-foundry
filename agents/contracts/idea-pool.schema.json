{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IdeaPool",
  "type": "object",
  "required": ["week", "scored_at", "rubric_version", "candidates"],
  "properties": {
    "week": {
      "type": "string",
      "pattern": "^\\d{4}-W\\d{2}$"
    },
    "scored_at": {
      "type": "string",
      "format": "date-time"
    },
    "rubric_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "pitch", "pain", "scores", "score_total", "source_refs"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]{3,40}$",
            "description": "URL-safe id (lowercase, hyphens)"
          },
          "name": { "type": "string" },
          "pitch": { "type": "string", "maxLength": 200 },
          "pain": { "type": "string", "maxLength": 280 },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source", "source_id", "url"],
              "properties": {
                "source": { "enum": ["cws_productivity", "cws_devtools", "hn_show_hn", "reddit_chrome_extensions", "reddit_sideproject", "reddit_internet_is_beautiful"] },
                "source_id": { "type": "string" },
                "url": { "type": "string", "format": "uri" }
              }
            }
          },
          "scores": {
            "type": "object",
            "required": ["demand", "wtp", "buildability", "defensibility"],
            "properties": {
              "demand": { "type": "number", "minimum": 0, "maximum": 10 },
              "wtp": { "type": "number", "minimum": 0, "maximum": 10 },
              "buildability": { "type": "number", "minimum": 0, "maximum": 10 },
              "defensibility": { "type": "number", "minimum": 0, "maximum": 10 }
            }
          },
          "score_total": {
            "type": "number",
            "minimum": 0,
            "maximum": 10
          },
          "monetization_hint": {
            "type": "object",
            "properties": {
              "audience": { "type": "string" },
              "model": { "type": "string" },
              "tier": { "type": "string" },
              "monthly_price_usd": { "type": ["number", "null"] }
            }
          },
          "dedup_state": {
            "type": "object",
            "properties": {
              "is_duplicate": { "type": "boolean" },
              "nearest_match_id": { "type": "string" },
              "jaccard_with_nearest": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
