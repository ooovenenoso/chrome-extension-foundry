# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
*.zip
*.crx
*.pem

# Secrets (NEVER commit)
.env
.env.*
!.env.example
secrets/
*.key
*.pem.enc

# Vercel
.vercel/

# Playwright
test-results/
playwright-report/
playwright/.cache/
PLAYWRIGHT_BROWSERS_PATH=0

# OS
.DS_Store
Thumbs.db

# Hermes tmp scratch (left by subagent runs that wrote inside repo)
.hermes-tmp.*
tests/**/.hermes-tmp.*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Env / secrets
.env
.env.local
*.local

# Cron output (heavy, append-only — keep manifest)
cron-output/*.json
!cron-output/.gitkeep
!cron-output/index.json

# Site build artifacts
site/.vercel/
site/out/

# Codex / generation cache
.codex-cache/
__pycache__/
*.pyc
