# MiniMax API credentials for the chrome-extension-idea-factory.
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# Production: set as a GitHub Actions secret via `gh secret set MINIMAX_API_KEY`.

# MiniMax (https://api.minimax.io) — required for research-collector
MINIMAX_API_KEY=

# Optional overrides (defaults shown)
MINIMAX_MODEL=MiniMax-M2.7-highspeed
MINIMAX_BASE_URL=https://api.minimax.io/v1
